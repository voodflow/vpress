{
    "name": "voodflow/vpress",
    "description": "Voodflow plugin — VitePress-style public frontend theme and Filament site pages for Laravel.",
    "version": "0.0.1",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "vitepress",
        "theme",
        "cms",
        "voodflow"
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0",
        "jeffersongoncalves/filament-cookie-consent": "^3.2",
        "ralphjsmit/laravel-seo": "^1.8",
        "spatie/laravel-package-tools": "^1.15",
        "spatie/laravel-settings": "^3.0|^4.0",
        "spatie/laravel-sluggable": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Voodflow\\Vpress\\": "src/",
            "Voodflow\\Vpress\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Voodflow\\Vpress\\VpressServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
